{"name":"Lightning Reflexes","type":"advance","img":"icons/skills/movement/arrow-upward-yellow.webp","system":{"tier":3,"name":"","description":"<p><strong>Tier 3 Initiative Advance &bull; Reaction</strong></p>\n<p><strong>Prerequisites&nbsp;</strong>Initiative 7, at least two Reaction advances</p>\n<p><strong>Effect&nbsp;</strong>You may take up to two reactions per round.</p>","xpCost":600,"hpBonus":3,"fpBonus":3},"effects":[],"flags":{"core":{"sourceId":"Item.Wi8NEemkCXm4BBSU"}},"_stats":{"systemId":"ashen","systemVersion":"0.3.2","coreVersion":"10.312","createdTime":1768055282827,"modifiedTime":1774472001611,"lastModifiedBy":"3coP1hWuS5N2Xu17"},"folder":null,"sort":0,"ownership":{"default":0,"3coP1hWuS5N2Xu17":3},"_id":"coF9z7CJchzVy6wA"}
