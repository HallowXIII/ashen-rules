{"name":"Silvered Force Sword","type":"meleeWeapon","img":"icons/weapons/swords/sword-runed-glowing.webp","effects":[],"flags":{"core":{"sourceId":"Item.5c7RvjH3D2ymca8y"}},"system":{"tier":2,"name":"","description":"<p>This shortsword uses force projector technology to enhance armor penetration. It is spellbound to increase effectiveness against undead creatures, and it has an ablative outer coating of silver that remains in the wounds caused by it.</p>\n<p><strong>Undeadbane:</strong> This sword inflicts 1d6 additional damage against undead creatures.</p>\n<p>&nbsp;</p>\n<p><strong>Keywords: </strong>Sidearm, Silvered</p>","bulk":0.5,"charge":2,"class":"light","type":"improvised","properties":"","equipped":false,"hands":1,"damageType":"Slashing","damage":"1d6+6","ap":4,"hitBonus":3,"increment":0,"maxHits":4,"quantity":null,"subType":"Sword","targetArmor":"Armor"},"_stats":{"systemId":"ashen","systemVersion":"0.3.1","coreVersion":"10.312","createdTime":1763401100012,"modifiedTime":1763401100012,"lastModifiedBy":"3coP1hWuS5N2Xu17"},"folder":null,"sort":0,"ownership":{"default":0,"3coP1hWuS5N2Xu17":3},"_id":"PUyLkODYlDEggzLZ"}
